  "summary_of_bugs_against_current_POM": [
    {
      "tab": 1,
      "field": "lcAmountInput",
      "issue": "POM selector '#lc-amount_field input' does NOT exist in live DOM (id is 'lc-amount', no '_field' suffix). Fallback 'input[id*=\"lc-amount\"]' is unsafe because it matches the currency selector's underlying input too.",
      "fix": "Replace with 'oj-input-text#lc-amount input' or directly target id='lc-amount|input'."
    },
    {
      "tab": 1,
      "field": "additionalAmountsCovered (39C)",
      "issue": "POM uses 'input[id*=\"AdditionalAmount\"]'. The inner editable element is a <textarea>, not <input>, so the selector returns nothing.",
      "fix": "Use 'oj-text-area#AdditionalAmountCovered8411447 textarea' or [id=\"AdditionalAmountCovered8411447|input\"]."
    },
    {
      "tab": 1,
      "field": "creditAvailableBy (41A)",
      "issue": "Required LOV missing from POM entirely. Tab 1 cannot Submit unless this is set. Existing happy-path tests pass only because the form must currently default to a value before the rescrape — or because the previous test runs left a draft selection. Confirmed required=true on live DOM.",
      "fix": "Add a private locator + helper (e.g. `setCreditAvailableBy(name)`) and invoke it inside fillLcDetails before Verify."
    },
    {
      "tab": 1,
      "field": "creditAvailableWith (radio)",
      "issue": "Tab 1 'SWIFT Code | Bank Address' radio not represented in POM. Label is 'Bank Address' (not 'Name and Address' which is the Tab 5 label).",
      "fix": "Optional helper. If a future test exercises the Bank-Address branch, add setCreditAvailableWith()."
    },
    {
      "tab": 1,
      "field": "applicantDetailsRadio",
      "issue": "Memory feedback_obdx_test_credentials.md claims 'Non-Customer radio absent' is SG-only. AE/corpmaker2 also shows ONLY 'Existing customer' — so the customisation is no longer SG-only. Tests TC-IMPLC-002 (asserts SG-only absence) and TC-IMPLC-003 (uses Non-customer) need to be reconciled.",
      "fix": "Update test assumptions and update the saved memory."
    },
    {
