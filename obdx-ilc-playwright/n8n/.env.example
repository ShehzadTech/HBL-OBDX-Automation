# OBDX Full QA Pipeline — environment template.
# Copy to n8n/.env (gitignored) and fill in real values before `docker compose up`.

# ── Timezone ──────────────────────────────────────────────────────────────
TZ=Asia/Karachi

# ── n8n external URL ──────────────────────────────────────────────────────
# Used by n8n to compose webhook URLs (HITL resume link, Drive trigger).
# Local-only:   leave defaults
# ngrok PoC:    set to your ngrok URL, e.g. https://abc123.ngrok-free.app
# Production:   set to your reverse-proxy hostname
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# ── Basic auth on n8n UI + webhooks ───────────────────────────────────────
# REQUIRED whenever WEBHOOK_URL is publicly reachable.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-before-exposing

# ── Claude Code CLI ───────────────────────────────────────────────────────
# The four Claude stages run via the Claude Code CLI (`claude -p`) inside
# the container, NOT via the Anthropic HTTP API. So no API key is needed.
#
# Auth: first time after `docker compose up`, run a one-time interactive
# login (see README "Authenticate Claude CLI" step). The auth persists in
# the obdx_qa_claude_auth volume.
#
# Optional: override the model the CLI uses. Defaults to "sonnet" (which
# the CLI resolves to the latest Sonnet your subscription has access to).
# Examples: sonnet | opus | haiku | claude-sonnet-4-6 | claude-opus-4-7
CLAUDE_MODEL=sonnet

# ── OBDX target ───────────────────────────────────────────────────────────
# OBDX is openly available — set the public URL directly.
OBDX_BASE_URL=https://obdx.example.bank/digx/v1/
OBDX_USER=corpmaker2
OBDX_PASSWORD=Admin@131
TEST_ENV=uat                     # dev | sit | uat — read by config/environments.ts

# ── Jira Cloud ────────────────────────────────────────────────────────────
# Used by the Jira Create Bug + Upload Attachment nodes.
# Create the n8n credential "Jira Cloud (OBDX)" with these same values on
# first boot. The container envs are mostly for documentation.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=qa-bot@your-org.com
JIRA_API_TOKEN=replace-with-atlassian-api-token
JIRA_PROJECT_KEY=OBDX

# ── Google Drive ──────────────────────────────────────────────────────────
# OAuth credential is created via the n8n UI on first boot (Drive doesn't
# support headless API-key auth). Record the folder ID here so the
# README quick-start steps are reproducible.
DRIVE_WATCH_FOLDER_ID=replace-with-google-drive-folder-id
