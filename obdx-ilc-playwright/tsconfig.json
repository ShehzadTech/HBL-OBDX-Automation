{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@pages/*":    ["pages/*"],
      "@utils/*":    ["utils/*"],
      "@fixtures/*": ["fixtures/*"],
      "@config/*":   ["config/*"],
      "@data/*":     ["data/*"]
    }
  },
  "include": [
    "playwright.config.ts",
    "tests/**/*.ts",
    "pages/**/*.ts",
    "utils/**/*.ts",
    "fixtures/**/*.ts",
    "config/**/*.ts",
    "data/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
